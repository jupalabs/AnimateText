{
  "indentation" : {
    "spaces" : 4
  },
  "indentConditionalCompilationBlocks" : false,
  "lineLength" : 100,
  "respectsExistingLineBreaks" : true,
  "rules" : {
    "AllPublicDeclarationsHaveDocumentation" : true,
    "NeverForceUnwrap" : true,
    "NeverUseForceTry" : true,
    "ValidateDocumentationComments" : true
  },
  "version" : 1
}
